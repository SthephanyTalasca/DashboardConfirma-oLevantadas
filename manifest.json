{
  "manifest_version": 3,
  "name": "Slack HubSpot Reader",
  "version": "1.0",
  "description": "Lê notificações do HubSpot no Slack e envia para dashboard",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://app.slack.com/*"],
  "content_scripts": [
    {
      "matches": ["https://app.slack.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
